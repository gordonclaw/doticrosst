---
const currentPath = Astro.url.pathname;

const navLinks = [
  {
    label: "Services",
    children: [
      { href: "/services/", label: "All Services" },
      { href: "/services/website-design/", label: "Website Design & SEO" },
      { href: "/services/hair-barber/", label: "Hair & Barber Specialists" },
    ],
  },
  { href: "/about/", label: "About" },
  { href: "/contact/", label: "Contact" },
];

function isActive(href: string) {
  if (href === "/") return currentPath === "/";
  return currentPath.startsWith(href);
}
---

<header class="sticky top-0 z-40 pt-4 sm:pt-6">
  <div class="mx-auto flex max-w-[1280px] items-center justify-between px-4 sm:px-6 lg:px-8">
    <a
      href="/"
      class="group inline-flex items-center gap-2 rounded-md bg-paper/80 px-3.5 py-2 backdrop-blur-md ring-1 ring-line transition-all duration-300 hover:ring-ink/15"
      aria-label="doticrosst home"
    >
      <span class="block h-1.5 w-1.5 rounded-[2px] bg-accent transition-transform duration-300 group-hover:scale-125"></span>
      <span class="font-heading text-[17px] font-semibold tracking-[-0.02em] text-ink">doticrosst</span>
    </a>

    <nav
      class="hidden items-center gap-1 rounded-md bg-paper/80 px-2 py-1.5 backdrop-blur-md ring-1 ring-line md:flex"
      aria-label="Main navigation"
    >
      {
        navLinks.map((link) =>
          link.children ? (
            <div class="relative group">
              <button
                class:list={[
                  "flex items-center gap-1.5 rounded px-3 py-1.5 text-[13px] font-medium transition-colors duration-200",
                  currentPath.startsWith("/services")
                    ? "text-ink"
                    : "text-mute hover:text-ink",
                ]}
                aria-expanded="false"
                aria-haspopup="true"
              >
                {link.label}
                <svg width="9" height="9" viewBox="0 0 12 12" fill="none" class="transition-transform duration-300 group-hover:rotate-180" aria-hidden="true">
                  <path d="M3 5l3 3 3-3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
                </svg>
              </button>
              <div class="invisible absolute left-1/2 top-full -translate-x-1/2 pt-3 opacity-0 transition-all duration-300 group-hover:visible group-hover:opacity-100">
                <div class="min-w-[240px] rounded-lg border border-line bg-paper p-1.5 shadow-[0_18px_40px_-20px_rgba(26,26,26,0.18)]">
                  {link.children.map((child) => (
                    <a
                      href={child.href}
                      class:list={[
                        "block rounded-md px-3.5 py-2.5 text-[13px] transition-colors duration-200",
                        isActive(child.href)
                          ? "bg-cream font-medium text-ink"
                          : "text-mute hover:bg-cream hover:text-ink",
                      ]}
                    >
                      {child.label}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          ) : (
            <a
              href={link.href}
              class:list={[
                "rounded px-3 py-1.5 text-[13px] font-medium transition-colors duration-200",
                isActive(link.href) ? "text-ink" : "text-mute hover:text-ink",
              ]}
            >
              {link.label}
            </a>
          )
        )
      }
    </nav>

    <div class="hidden md:flex">
      <a
        href="/get-started/"
        class="group inline-flex items-center gap-2 rounded-md bg-ink px-4 py-2.5 text-[13px] font-medium text-cream transition-all duration-300 hover:bg-ink-soft active:translate-y-[1px]"
      >
        Start a project
        <svg width="11" height="11" viewBox="0 0 12 12" fill="none" class="transition-transform duration-300 group-hover:translate-x-0.5" aria-hidden="true">
          <path d="M2.5 6h7m0 0L6 2.5M9.5 6L6 9.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </div>

    <button
      class="flex flex-col gap-1.5 rounded-md bg-paper/80 p-2.5 ring-1 ring-line backdrop-blur-md md:hidden"
      id="mobile-toggle"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <span class="block h-0.5 w-4 rounded bg-ink transition-all duration-300"></span>
      <span class="block h-0.5 w-4 rounded bg-ink transition-all duration-300"></span>
    </button>
  </div>

  <div class="hidden md:hidden" id="mobile-nav">
    <div class="mx-auto mt-3 max-w-[1280px] px-4 sm:px-6">
      <nav
        class="rounded-lg border border-line bg-paper p-3 shadow-[0_24px_50px_-20px_rgba(26,26,26,0.18)]"
        aria-label="Mobile navigation"
      >
        <div class="flex flex-col gap-0.5">
          {
            navLinks.map((link) =>
              link.children ? (
                link.children.map((child) => (
                  <a
                    href={child.href}
                    class:list={[
                      "rounded-md px-3 py-2.5 text-[14px] transition-colors duration-200",
                      isActive(child.href)
                        ? "bg-cream font-medium text-ink"
                        : "text-mute hover:bg-cream hover:text-ink",
                    ]}
                  >
                    {child.label}
                  </a>
                ))
              ) : (
                <a
                  href={link.href}
                  class:list={[
                    "rounded-md px-3 py-2.5 text-[14px] transition-colors duration-200",
                    isActive(link.href)
                      ? "bg-cream font-medium text-ink"
                      : "text-mute hover:bg-cream hover:text-ink",
                  ]}
                >
                  {link.label}
                </a>
              )
            )
          }
          <a
            href="/get-started/"
            class="mt-2 inline-flex items-center justify-center gap-2 rounded-md bg-ink px-4 py-3 text-[14px] font-medium text-cream"
          >
            Start a project
          </a>
        </div>
      </nav>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById("mobile-toggle") as HTMLButtonElement;
  const nav = document.getElementById("mobile-nav") as HTMLElement;
  const bars = toggle?.querySelectorAll("span");

  toggle?.addEventListener("click", () => {
    const open = toggle.getAttribute("aria-expanded") === "true";
    toggle.setAttribute("aria-expanded", String(!open));
    nav.classList.toggle("hidden");
    if (bars) {
      bars[0].classList.toggle("translate-y-1");
      bars[0].classList.toggle("rotate-45");
      bars[1].classList.toggle("-translate-y-1");
      bars[1].classList.toggle("-rotate-45");
    }
  });
</script>
