---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: "/", label: "Home" },
  {
    label: "Services",
    children: [
      { href: "/services/", label: "All Services" },
      { href: "/services/website-design/", label: "Website Design & SEO" },
      { href: "/services/hair-barber/", label: "Hair & Barber Specialists" },
    ],
  },
  { href: "/about/", label: "About" },
  { href: "/contact/", label: "Contact" },
];

function isActive(href: string) {
  if (href === "/") return currentPath === "/";
  return currentPath.startsWith(href);
}
---

<header class="sticky top-0 z-50 border-b border-gray-100 bg-white/95 backdrop-blur-md">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-4 sm:px-6 lg:px-8">
    <a href="/" class="flex items-center gap-2" aria-label="doticrosst home">
      <span class="text-lg tracking-[-0.03em] text-charcoal">dot<span class="font-semibold">icrosst</span></span>
    </a>

    <nav class="hidden items-center gap-8 md:flex" aria-label="Main navigation">
      {
        navLinks.map((link) =>
          link.children ? (
            <div class="relative group">
              <button
                class:list={[
                  "flex items-center gap-1 text-sm transition-colors duration-200",
                  currentPath.startsWith("/services")
                    ? "text-charcoal"
                    : "text-gray-500 hover:text-charcoal",
                ]}
                aria-expanded="false"
                aria-haspopup="true"
              >
                {link.label}
                <svg width="10" height="10" viewBox="0 0 12 12" fill="none" class="transition-transform duration-200 group-hover:rotate-180" aria-hidden="true">
                  <path d="M3 5l3 3 3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                </svg>
              </button>
              <div class="invisible absolute left-0 top-full pt-3 opacity-0 transition-all duration-200 group-hover:visible group-hover:opacity-100">
                <div class="min-w-[220px] rounded-xl border border-gray-100 bg-white p-2 shadow-xl">
                  {link.children.map((child) => (
                    <a
                      href={child.href}
                      class:list={[
                        "block rounded-lg px-4 py-2.5 text-sm transition-colors duration-200",
                        isActive(child.href)
                          ? "bg-gray-50 font-medium text-charcoal"
                          : "text-gray-500 hover:bg-gray-50 hover:text-charcoal",
                      ]}
                    >
                      {child.label}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          ) : (
            <a
              href={link.href}
              class:list={[
                "text-sm transition-colors duration-200",
                isActive(link.href)
                  ? "text-charcoal"
                  : "text-gray-500 hover:text-charcoal",
              ]}
            >
              {link.label}
            </a>
          )
        )
      }
    </nav>

    <div class="hidden items-center md:flex">
      <a
        href="/get-started/"
        class="rounded-full bg-charcoal px-5 py-2 text-sm font-medium text-white transition-all duration-200 hover:bg-charcoal-light"
      >
        Start a Project
      </a>
    </div>

    <button class="flex flex-col gap-1.5 p-2 md:hidden" id="mobile-toggle" aria-label="Toggle menu" aria-expanded="false">
      <span class="block h-0.5 w-5 rounded bg-charcoal transition-all duration-200"></span>
      <span class="block h-0.5 w-5 rounded bg-charcoal transition-all duration-200"></span>
      <span class="block h-0.5 w-5 rounded bg-charcoal transition-all duration-200"></span>
    </button>
  </div>

  <div class="hidden border-t border-gray-100 bg-white md:hidden" id="mobile-nav">
    <nav class="mx-auto max-w-6xl px-4 py-4 sm:px-6" aria-label="Mobile navigation">
      <div class="flex flex-col gap-1">
        {
          navLinks.map((link) =>
            link.children ? (
              link.children.map((child) => (
                <a
                  href={child.href}
                  class:list={[
                    "rounded-lg px-4 py-3 text-sm transition-colors duration-200",
                    isActive(child.href)
                      ? "bg-gray-50 text-charcoal"
                      : "text-gray-500 hover:bg-gray-50 hover:text-charcoal",
                  ]}
                >
                  {child.label}
                </a>
              ))
            ) : (
              <a
                href={link.href}
                class:list={[
                  "rounded-lg px-4 py-3 text-sm transition-colors duration-200",
                  isActive(link.href)
                    ? "bg-gray-50 text-charcoal"
                    : "text-gray-500 hover:bg-gray-50 hover:text-charcoal",
                ]}
              >
                {link.label}
              </a>
            )
          )
        }
        <a
          href="/get-started/"
          class="mt-2 rounded-full bg-charcoal px-5 py-3 text-center text-sm font-medium text-white"
        >
          Start a Project
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById("mobile-toggle") as HTMLButtonElement;
  const nav = document.getElementById("mobile-nav") as HTMLElement;
  const bars = toggle?.querySelectorAll("span");

  toggle?.addEventListener("click", () => {
    const open = toggle.getAttribute("aria-expanded") === "true";
    toggle.setAttribute("aria-expanded", String(!open));
    nav.classList.toggle("hidden");
    if (bars) {
      bars[0].classList.toggle("translate-y-2");
      bars[0].classList.toggle("rotate-45");
      bars[1].classList.toggle("opacity-0");
      bars[2].classList.toggle("-translate-y-2");
      bars[2].classList.toggle("-rotate-45");
    }
  });
</script>
