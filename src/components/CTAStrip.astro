---
interface Props {
  heading?: string;
  text?: string;
  buttonText?: string;
  buttonHref?: string;
}

const {
  heading = "Ready to grow your business?",
  text = "Book a free discovery call and let's talk about what doticrosst can do for you.",
  buttonText = "Get in Touch",
  buttonHref = "/contact/",
} = Astro.props;
---

<section class="border-t border-gray-100 py-32">
  <div class="mx-auto max-w-6xl px-4 text-center sm:px-6 lg:px-8">
    <h2 class="text-3xl font-bold text-charcoal sm:text-4xl lg:text-5xl">{heading}</h2>
    <p class="mx-auto mt-6 max-w-xl text-lg leading-relaxed text-gray-500">
      {text}
    </p>
    <a
      href={buttonHref}
      class="mt-10 inline-block rounded-full bg-charcoal px-8 py-4 text-sm font-medium text-white transition-all duration-200 hover:bg-charcoal-light"
    >
      {buttonText}
    </a>
  </div>
</section>
