---
interface Props {
  heading?: string;
  text?: string;
  buttonText?: string;
  buttonHref?: string;
}

const {
  heading = "Ready for a website that actually works?",
  text = "Fill in the scoping form. We come back with a clear quote within one working day.",
  buttonText = "Start a project",
  buttonHref = "/get-started/",
} = Astro.props;
---

<section class="border-t border-line bg-ink py-24 text-cream lg:py-32">
  <div class="mx-auto grid max-w-[1280px] grid-cols-12 gap-x-6 gap-y-10 px-4 sm:px-6 lg:gap-x-10 lg:px-8">
    <div class="col-span-12 lg:col-span-7">
      <p class="font-mono text-[11px] uppercase tracking-[0.18em] text-cream/45">Next step</p>
      <h2 class="mt-4 font-heading text-[clamp(2rem,4.6vw,3.6rem)] font-semibold leading-[1.02] tracking-[-0.025em] text-cream">
        {heading}
      </h2>
    </div>

    <div class="col-span-12 flex flex-col justify-end gap-7 lg:col-span-4 lg:col-start-9">
      <p class="max-w-[42ch] text-[15.5px] leading-[1.6] text-cream/70">
        {text}
      </p>
      <a
        href={buttonHref}
        class="group inline-flex w-fit items-center gap-3 rounded-md bg-cream px-5 py-3.5 text-[14px] font-medium text-ink transition-all duration-300 hover:bg-paper active:translate-y-[1px]"
      >
        {buttonText}
        <svg width="13" height="13" viewBox="0 0 14 14" fill="none" class="transition-transform duration-300 group-hover:translate-x-0.5" aria-hidden="true">
          <path d="M3 7h8m0 0L7 3M11 7l-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </div>
  </div>
</section>
