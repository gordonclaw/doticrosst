---
interface Props {
  heading?: string;
  text?: string;
  buttonText?: string;
  buttonHref?: string;
}

const {
  heading = "Ready to grow your business?",
  text = "Book a free discovery call and let's talk about what doticrosst can do for you.",
  buttonText = "Get in Touch",
  buttonHref = "/contact/",
} = Astro.props;
---

<section class="relative overflow-hidden bg-charcoal py-24">
  <div class="absolute inset-0 bg-gradient-to-br from-accent/20 via-transparent to-accent-light/10"></div>
  <div class="relative mx-auto max-w-3xl px-4 text-center sm:px-6">
    <h2 class="text-3xl font-black text-white sm:text-4xl">{heading}</h2>
    <p class="mx-auto mt-4 max-w-xl text-lg leading-relaxed text-gray-300">
      {text}
    </p>
    <a
      href={buttonHref}
      class="mt-8 inline-flex items-center gap-2 rounded-lg bg-accent px-8 py-4 text-base font-semibold text-white transition-all duration-200 hover:-translate-y-0.5 hover:bg-accent-light hover:shadow-lg hover:shadow-accent/25"
    >
      {buttonText}
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
      </svg>
    </a>
  </div>
</section>
