---
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  items: FAQItem[];
}

const { items } = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: items.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer,
    },
  })),
};
---

<div>
  {
    items.map((item, i) => (
      <details class="group border-t border-line first:border-t-0">
        <summary class="grid cursor-pointer grid-cols-[auto_1fr_auto] items-baseline gap-5 py-6 text-left transition-colors duration-200 [&::-webkit-details-marker]:hidden">
          <span class="font-mono text-[11px] tabular-nums text-mute-faint">0{i + 1}</span>
          <span class="font-heading text-[17px] font-semibold tracking-[-0.01em] text-ink group-hover:text-ink-soft">
            {item.question}
          </span>
          <span class="grid h-7 w-7 place-items-center rounded-md border border-line text-mute transition-all duration-300 group-open:rotate-45 group-open:border-ink/20 group-open:text-ink">
            <svg class="h-3 w-3" viewBox="0 0 12 12" fill="none" aria-hidden="true">
              <path d="M6 2v8M2 6h8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
            </svg>
          </span>
        </summary>
        <div class="grid grid-cols-[auto_1fr_auto] gap-5 pb-6">
          <span></span>
          <p class="max-w-[58ch] text-[14.5px] leading-[1.65] text-mute">{item.answer}</p>
          <span></span>
        </div>
      </details>
    ))
  }
</div>

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
