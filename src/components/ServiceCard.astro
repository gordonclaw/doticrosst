---
interface Props {
  title: string;
  description: string;
  href: string;
  icon?: string;
}

const { title, description, href, icon } = Astro.props;
---

<a
  href={href}
  class="group flex flex-col border-t border-gray-100 py-10 transition-all duration-300"
>
  {
    icon && (
      <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-lg bg-gray-100 text-charcoal">
        <div class="h-5 w-5" set:html={icon} />
      </div>
    )
  }
  <h3 class="text-lg font-semibold text-charcoal">{title}</h3>
  <p class="mt-3 flex-1 text-sm leading-relaxed text-gray-500">{description}</p>
  <span class="mt-5 inline-flex items-center gap-1.5 text-sm text-gray-400 underline underline-offset-4 decoration-gray-300 transition-all duration-200 group-hover:text-charcoal group-hover:decoration-charcoal group-hover:gap-2.5">
    Learn more
  </span>
</a>
