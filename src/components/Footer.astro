---
const year = new Date().getFullYear();
---

<footer class="border-t border-gray-100 py-20">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="grid gap-12 sm:grid-cols-2 lg:grid-cols-5">
      <div class="lg:col-span-2">
        <span class="text-lg tracking-[-0.03em] text-charcoal">dot<span class="font-semibold">icrosst</span></span>
        <p class="mt-4 max-w-xs text-sm leading-relaxed text-gray-400">
          Website design and SEO for small businesses. Specialist division for hairdressers and barbers.
        </p>
      </div>

      <div>
        <p class="mb-4 text-xs font-medium text-gray-400">Services</p>
        <ul class="space-y-3">
          <li><a href="/services/website-design/" class="text-sm text-gray-500 transition-colors duration-200 hover:text-charcoal">Website Design & SEO</a></li>
          <li><a href="/services/hair-barber/" class="text-sm text-gray-500 transition-colors duration-200 hover:text-charcoal">Hair & Barber</a></li>
        </ul>
      </div>

      <div>
        <p class="mb-4 text-xs font-medium text-gray-400">Company</p>
        <ul class="space-y-3">
          <li><a href="/about/" class="text-sm text-gray-500 transition-colors duration-200 hover:text-charcoal">About</a></li>
          <li><a href="/contact/" class="text-sm text-gray-500 transition-colors duration-200 hover:text-charcoal">Contact</a></li>
          <li><a href="/privacy/" class="text-sm text-gray-500 transition-colors duration-200 hover:text-charcoal">Privacy</a></li>
          <li><a href="/terms/" class="text-sm text-gray-500 transition-colors duration-200 hover:text-charcoal">Terms</a></li>
        </ul>
      </div>

      <div>
        <p class="mb-4 text-xs font-medium text-gray-400">Get in touch</p>
        <ul class="space-y-3">
          <li>
            <a href="mailto:craig@doticrosst.com" class="text-sm text-gray-500 transition-colors duration-200 hover:text-charcoal">
              craig@doticrosst.com
            </a>
          </li>
          <li>
            <a href="https://www.instagram.com/dottheicrosst" target="_blank" rel="noopener noreferrer" class="text-sm text-gray-500 transition-colors duration-200 hover:text-charcoal">
              Instagram
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-16 border-t border-gray-100 pt-8">
      <p class="text-xs text-gray-400">&copy; {year} doticrosst</p>
    </div>
  </div>
</footer>
