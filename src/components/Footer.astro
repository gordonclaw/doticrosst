---
const year = new Date().getFullYear();
---

<footer class="bg-charcoal pt-20 pb-10">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid gap-12 sm:grid-cols-2 lg:grid-cols-4">
      <div class="lg:col-span-1">
        <span class="text-xl font-light tracking-tight text-white">
          dot<strong class="font-extrabold text-accent-light">icrosst</strong>
        </span>
        <p class="mt-4 max-w-xs leading-relaxed text-gray-400">
          Website design and SEO agency for small businesses. Specialist
          division for hairdressers and barbers.
        </p>
      </div>

      <div>
        <h4 class="mb-4 text-xs font-bold uppercase tracking-[0.2em] text-gray-400">
          Services
        </h4>
        <ul class="space-y-3">
          <li><a href="/services/website-design/" class="text-sm text-gray-400 transition-colors duration-200 hover:text-white">Website Design & SEO</a></li>
          <li><a href="/services/hair-barber/" class="text-sm text-gray-400 transition-colors duration-200 hover:text-white">Hair & Barber Specialists</a></li>
        </ul>
      </div>

      <div>
        <h4 class="mb-4 text-xs font-bold uppercase tracking-[0.2em] text-gray-400">
          Portfolio
        </h4>
        <ul class="space-y-3">
          <li><a href="https://hairbydom.co.uk" target="_blank" rel="noopener noreferrer" class="text-sm text-gray-400 transition-colors duration-200 hover:text-white">Hair by Dom</a></li>
          <li><a href="https://apptmint.co.uk" target="_blank" rel="noopener noreferrer" class="text-sm text-gray-400 transition-colors duration-200 hover:text-white">Apptmint</a></li>
        </ul>
      </div>

      <div>
        <h4 class="mb-4 text-xs font-bold uppercase tracking-[0.2em] text-gray-400">
          Company
        </h4>
        <ul class="space-y-3">
          <li><a href="/about/" class="text-sm text-gray-400 transition-colors duration-200 hover:text-white">About</a></li>
          <li><a href="/contact/" class="text-sm text-gray-400 transition-colors duration-200 hover:text-white">Contact</a></li>
          <li><a href="/privacy/" class="text-sm text-gray-400 transition-colors duration-200 hover:text-white">Privacy Policy</a></li>
          <li><a href="/terms/" class="text-sm text-gray-400 transition-colors duration-200 hover:text-white">Terms of Service</a></li>
        </ul>
      </div>

      <div>
        <h4 class="mb-4 text-xs font-bold uppercase tracking-[0.2em] text-gray-400">
          Get in Touch
        </h4>
        <ul class="space-y-3">
          <li>
            <a href="mailto:hello@doticrosst.com" class="text-sm text-gray-400 transition-colors duration-200 hover:text-accent-light">
              hello@doticrosst.com
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-16 border-t border-white/10 pt-8 text-center">
      <p class="text-sm text-gray-500">&copy; {year} doticrosst. All rights reserved.</p>
    </div>
  </div>
</footer>
