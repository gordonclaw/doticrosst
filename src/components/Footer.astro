---
const year = new Date().getFullYear();
---

<footer class="bg-charcoal pt-20 pb-10">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid gap-12 sm:grid-cols-2 lg:grid-cols-4">
      <div class="lg:col-span-1">
        <span class="text-xl font-light tracking-tight text-white">
          dot<span class="font-extrabold text-accent-light">icrosst</span>
        </span>
        <p class="mt-4 max-w-xs leading-relaxed text-gray-400">
          Website design and SEO agency for small businesses. Specialist
          division for hairdressers and barbers.
        </p>
      </div>

      <div>
        <p class="mb-4 text-xs font-bold uppercase tracking-[0.2em] text-gray-400">
          Services
        </p>
        <ul class="space-y-3">
          <li><a href="/services/website-design/" class="text-sm text-gray-400 transition-colors duration-200 hover:text-white">Website Design & SEO</a></li>
          <li><a href="/services/hair-barber/" class="text-sm text-gray-400 transition-colors duration-200 hover:text-white">Hair & Barber Specialists</a></li>
        </ul>
      </div>

      <div>
        <p class="mb-4 text-xs font-bold uppercase tracking-[0.2em] text-gray-400">
          Portfolio
        </p>
        <ul class="space-y-3">
          <li><a href="https://hairbydom.co.uk" target="_blank" rel="noopener noreferrer" class="text-sm text-gray-400 transition-colors duration-200 hover:text-white">Hair by Dom</a></li>
          <li><a href="https://apptmint.co.uk" target="_blank" rel="noopener noreferrer" class="text-sm text-gray-400 transition-colors duration-200 hover:text-white">Apptmint</a></li>
        </ul>
      </div>

      <div>
        <p class="mb-4 text-xs font-bold uppercase tracking-[0.2em] text-gray-400">
          Company
        </p>
        <ul class="space-y-3">
          <li><a href="/about/" class="text-sm text-gray-400 transition-colors duration-200 hover:text-white">About</a></li>
          <li><a href="/contact/" class="text-sm text-gray-400 transition-colors duration-200 hover:text-white">Contact</a></li>
          <li><a href="/privacy/" class="text-sm text-gray-400 transition-colors duration-200 hover:text-white">Privacy Policy</a></li>
          <li><a href="/terms/" class="text-sm text-gray-400 transition-colors duration-200 hover:text-white">Terms of Service</a></li>
        </ul>
      </div>

      <div>
        <p class="mb-4 text-xs font-bold uppercase tracking-[0.2em] text-gray-400">
          Get in Touch
        </p>
        <ul class="space-y-3">
          <li>
            <a href="mailto:craig@doticrosst.com" class="text-sm text-gray-400 transition-colors duration-200 hover:text-accent-light">
              craig@doticrosst.com
            </a>
          </li>
          <li>
            <a href="https://www.instagram.com/dottheicrosst" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm text-gray-400 transition-colors duration-200 hover:text-accent-light">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
