---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import CTAStrip from "../components/CTAStrip.astro";
---

<BaseLayout
  title="About Us | Web Design & SEO Agency | doticrosst"
  description="We're a small web design and SEO agency that builds fast, honest websites for small businesses. Specialist division for hairdressers and barbers."
>
  <section class="pt-12 pb-32">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <Breadcrumb
        items={[
          { label: "Home", href: "/" },
          { label: "About" },
        ]}
      />
      <div class="mt-12 max-w-3xl">
        <h1 class="text-4xl font-bold leading-tight text-charcoal sm:text-5xl lg:text-6xl">
          A web design agency where detail matters.
        </h1>
        <p class="mt-8 text-lg leading-relaxed text-gray-500">
          The name is a play on "dot the i's and cross the t's". Attention to
          detail is what separates a website that works from one that just exists.
        </p>
      </div>
    </div>
  </section>

  <section class="border-t border-gray-100 py-32">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-16 lg:grid-cols-2">
        <div>
          <h2 class="text-3xl font-bold text-charcoal">Who we are</h2>
        </div>
        <div class="space-y-6">
          <p class="leading-relaxed text-gray-500">
            doticrosst is a small web design and SEO agency based in the UK. We build fast,
            clean websites for small businesses, the kind that load in under a
            second, rank locally, and actually bring in enquiries.
          </p>
          <p class="leading-relaxed text-gray-500">
            We started with a specialist focus on hairdressers and barbers, an
            industry full of creative people being overcharged for clunky software
            and template websites. That division is still going strong, but we now
            work with small businesses across the board.
          </p>
          <p class="leading-relaxed text-gray-500">
            We don't use page builders. We don't charge for hosting. We don't
            lock you into platforms you can't leave. We hand-code every site,
            build on open tools, and give you something you actually own.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="border-t border-gray-100 py-32">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-16 lg:grid-cols-2">
        <div>
          <h2 class="text-3xl font-bold text-charcoal">Why detail matters</h2>
        </div>
        <div class="space-y-6">
          <p class="leading-relaxed text-gray-500">
            Most web agencies build with templates and page builders. The result is a website
            that looks like everyone else's, loads slowly, and gets buried in search results.
          </p>
          <p class="leading-relaxed text-gray-500">
            We take a different approach. Every detail matters, from how quickly your
            images load on a phone over 4G, to whether your heading tags are structured
            correctly for Google, to the exact words on your call-to-action buttons.
          </p>
          <p class="leading-relaxed text-gray-500">
            A one-second improvement in page speed can increase conversions by
            up to 27%. Properly structured local SEO markup can be the difference between
            appearing in the map pack or not. These details compound over time.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="border-t border-gray-100 py-32">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-charcoal">How we work</h2>
      <div class="mt-16 grid gap-16 sm:grid-cols-3">
        <div>
          <h3 class="text-lg font-semibold text-charcoal">No bloat</h3>
          <p class="mt-3 text-sm leading-relaxed text-gray-500">
            We don't build things you don't need. Every page, every feature
            earns its place by making you money or saving you time.
          </p>
        </div>
        <div>
          <h3 class="text-lg font-semibold text-charcoal">No lock-in</h3>
          <p class="mt-3 text-sm leading-relaxed text-gray-500">
            You own your website, your code, your content. We build on open
            tools so you're never trapped by a vendor or tied to us.
          </p>
        </div>
        <div>
          <h3 class="text-lg font-semibold text-charcoal">No jargon</h3>
          <p class="mt-3 text-sm leading-relaxed text-gray-500">
            We explain things in plain English. You'll always know what we're
            building, why, and what it costs.
          </p>
        </div>
      </div>
    </div>
  </section>

  <CTAStrip
    heading="Let's have a chat."
    text="No pitch, no pressure. Just a conversation about where your business is and where you want it to go."
    buttonText="Start a Project"
    buttonHref="/get-started/"
  />
</BaseLayout>
