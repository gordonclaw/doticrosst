---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import FAQ from "../../components/FAQ.astro";
import CTAStrip from "../../components/CTAStrip.astro";
---

<BaseLayout
  title="Booking Systems for Hairdressers & Barbers | doticrosst"
  description="Online booking built for salons and barbershops. No per-appointment fees, no lock-in. Your clients book 24/7 while you focus on cutting hair."
>
  <div class="container">
    <Breadcrumb
      items={[
        { label: "Home", href: "/" },
        { label: "Services", href: "/services/" },
        { label: "Booking Systems" },
      ]}
    />
  </div>

  <section class="section">
    <div class="container">
      <div class="page-intro">
        <h1>Online booking that works for you, not against you</h1>
        <p>
          Most booking platforms charge you per appointment or lock you into
          monthly fees that grow as your business does. BookJanus is different --
          a booking system built specifically for hairdressers and barbers, with
          a flat fee and no hidden costs.
        </p>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <h2>What you get</h2>
      </div>
      <div class="grid-3">
        <div class="feature card">
          <h3>24/7 online booking</h3>
          <p>
            Clients book at any time -- evenings, weekends, between appointments.
            No more back-and-forth on Instagram DMs.
          </p>
        </div>
        <div class="feature card">
          <h3>Staff scheduling</h3>
          <p>
            Each stylist or barber gets their own availability. Clients pick who
            they want and see only open slots.
          </p>
        </div>
        <div class="feature card">
          <h3>Automated reminders</h3>
          <p>
            SMS and email reminders cut no-shows dramatically. Set them once,
            forget about them.
          </p>
        </div>
        <div class="feature card">
          <h3>Service menu</h3>
          <p>
            List your cuts, colours, and treatments with prices and durations.
            Clients know what to expect before they walk in.
          </p>
        </div>
        <div class="feature card">
          <h3>No per-booking fees</h3>
          <p>
            Flat monthly cost. Whether you get 10 bookings or 1,000, the price
            stays the same.
          </p>
        </div>
        <div class="feature card">
          <h3>Your brand, your site</h3>
          <p>
            The booking page lives on your domain and matches your branding. It's
            yours, not a third-party marketplace.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing placeholder -->
  <section class="section" id="pricing">
    <div class="container">
      <div class="section-header">
        <h2>Simple pricing</h2>
        <p>No setup fees. No contracts. Cancel any time.</p>
      </div>
      <div class="grid-3 pricing-grid">
        <div class="card pricing-card">
          <h3>Solo</h3>
          <p class="price">TBC<span>/month</span></p>
          <ul class="pricing-list">
            <li>1 staff member</li>
            <li>Unlimited bookings</li>
            <li>Email reminders</li>
            <li>Custom branding</li>
          </ul>
          <a href="/contact/" class="btn btn-secondary">Get Started</a>
        </div>
        <div class="card pricing-card featured">
          <h3>Team</h3>
          <p class="price">TBC<span>/month</span></p>
          <ul class="pricing-list">
            <li>Up to 5 staff</li>
            <li>Unlimited bookings</li>
            <li>SMS + email reminders</li>
            <li>Custom branding</li>
            <li>Google Calendar sync</li>
          </ul>
          <a href="/contact/" class="btn btn-primary">Get Started</a>
        </div>
        <div class="card pricing-card">
          <h3>Salon</h3>
          <p class="price">TBC<span>/month</span></p>
          <ul class="pricing-list">
            <li>Unlimited staff</li>
            <li>Unlimited bookings</li>
            <li>SMS + email reminders</li>
            <li>Custom branding</li>
            <li>Google Calendar sync</li>
            <li>Priority support</li>
          </ul>
          <a href="/contact/" class="btn btn-secondary">Get Started</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <h2>Frequently asked questions</h2>
      </div>
      <FAQ
        items={[
          {
            question: "Can I migrate from my current booking system?",
            answer:
              "Yes. We'll handle the migration for you, including importing your existing client list and upcoming appointments.",
          },
          {
            question: "Do my clients need to create an account to book?",
            answer:
              "No. Clients can book as a guest with just their name and contact details. No app downloads or account creation required.",
          },
          {
            question: "What happens if I cancel?",
            answer:
              "You keep all your data. We'll export everything for you and help you transition if needed. No penalty, no hassle.",
          },
          {
            question: "Can I take payments through the booking system?",
            answer:
              "Yes. We integrate with Stripe for online deposits or full prepayment. You only pay standard Stripe processing fees.",
          },
        ]}
      />
    </div>
  </section>

  <CTAStrip
    heading="Stop losing bookings to voicemail"
    text="Let your clients book when it suits them. Set up takes days, not weeks."
  />
</BaseLayout>

<style>
  .page-intro {
    max-width: 680px;
  }

  .page-intro h1 {
    margin-bottom: var(--space-lg);
  }

  .page-intro p {
    color: var(--text-light);
    font-size: 1.1rem;
    line-height: 1.7;
  }

  .feature h3 {
    margin-bottom: var(--space-sm);
  }

  .feature p {
    color: var(--text-light);
    font-size: 0.95rem;
  }

  /* Pricing */
  .pricing-card {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .pricing-card.featured {
    border-color: var(--primary);
    box-shadow: var(--shadow-md);
    position: relative;
  }

  .pricing-card h3 {
    margin-bottom: var(--space-sm);
  }

  .price {
    font-size: 2rem;
    font-weight: 800;
    color: var(--primary);
    margin-bottom: var(--space-lg);
  }

  .price span {
    font-size: 0.9rem;
    font-weight: 400;
    color: var(--text-light);
  }

  .pricing-list {
    text-align: left;
    margin-bottom: var(--space-xl);
    width: 100%;
  }

  .pricing-list li {
    padding: var(--space-sm) 0;
    border-bottom: 1px solid var(--border);
    font-size: 0.9rem;
    color: var(--text-light);
    padding-left: var(--space-lg);
    position: relative;
  }

  .pricing-list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 6px;
    height: 6px;
    background: var(--success);
    border-radius: 50%;
  }

  .pricing-card .btn {
    margin-top: auto;
    width: 100%;
    justify-content: center;
  }
</style>
