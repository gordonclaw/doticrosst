---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import FAQ from "../../components/FAQ.astro";
import CTAStrip from "../../components/CTAStrip.astro";
---

<BaseLayout
  title="Booking Systems for Hairdressers & Barbers | doticrosst"
  description="Online booking built for salons and barbershops. No per-appointment fees, no lock-in. Your clients book 24/7 while you focus on cutting hair."
>
  <section class="bg-charcoal py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <Breadcrumb
        items={[
          { label: "Home", href: "/" },
          { label: "Services", href: "/services/" },
          { label: "Booking Systems" },
        ]}
      />
      <div class="mt-4 max-w-2xl">
        <p class="text-sm font-bold uppercase tracking-[0.2em] text-accent-light">BookJanus</p>
        <h1 class="mt-3 text-4xl font-black text-white sm:text-5xl">
          Online booking that works for you
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-gray-300">
          Most booking platforms charge you per appointment or lock you into
          monthly fees that grow as your business does. BookJanus is different --
          a flat fee, no hidden costs, built for how you actually work.
        </p>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <p class="text-sm font-bold uppercase tracking-[0.2em] text-accent">Features</p>
        <h2 class="mt-2 text-3xl font-black text-charcoal sm:text-4xl">What you get</h2>
      </div>
      <div class="mt-14 grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
        {[
          { title: "24/7 online booking", desc: "Clients book at any time -- evenings, weekends, between appointments. No more back-and-forth on Instagram DMs.", icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>' },
          { title: "Staff scheduling", desc: "Each stylist or barber gets their own availability. Clients pick who they want and see only open slots.", icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>' },
          { title: "Automated reminders", desc: "SMS and email reminders cut no-shows dramatically. Set them once, forget about them.", icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>' },
          { title: "Service menu", desc: "List your cuts, colours, and treatments with prices and durations. Clients know what to expect before they walk in.", icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>' },
          { title: "No per-booking fees", desc: "Flat monthly cost. Whether you get 10 bookings or 1,000, the price stays the same.", icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>' },
          { title: "Your brand, your site", desc: "The booking page lives on your domain and matches your branding. It's yours, not a third-party marketplace.", icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>' },
        ].map((f) => (
          <div class="group rounded-2xl border border-gray-100 bg-white p-8 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-xl">
            <div class="mb-5 flex h-14 w-14 items-center justify-center rounded-xl bg-accent/10 text-accent transition-all duration-300 group-hover:bg-accent group-hover:text-white">
              <div class="h-6 w-6 transition-transform duration-300 group-hover:scale-110" set:html={f.icon} />
            </div>
            <h3 class="text-lg font-bold text-charcoal">{f.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-gray-500">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="bg-gray-50 py-20" id="pricing">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <p class="text-sm font-bold uppercase tracking-[0.2em] text-accent">Pricing</p>
        <h2 class="mt-2 text-3xl font-black text-charcoal sm:text-4xl">Simple pricing</h2>
        <p class="mx-auto mt-4 max-w-md text-gray-500">No setup fees. No contracts. Cancel any time.</p>
      </div>
      <div class="mx-auto mt-14 grid max-w-4xl grid-cols-1 gap-8 md:grid-cols-3">
        {[
          { name: "Solo", price: "TBC", features: ["1 staff member", "Unlimited bookings", "Email reminders", "Custom branding"], highlight: false },
          { name: "Team", price: "TBC", features: ["Up to 5 staff", "Unlimited bookings", "SMS + email reminders", "Custom branding", "Google Calendar sync"], highlight: true, badge: "Most Popular" },
          { name: "Salon", price: "TBC", features: ["Unlimited staff", "Unlimited bookings", "SMS + email reminders", "Custom branding", "Google Calendar sync", "Priority support"], highlight: false },
        ].map((plan) => (
          <div class:list={[
            "relative flex flex-col rounded-2xl border-2 p-8 transition-all duration-300 hover:-translate-y-1 hover:shadow-xl",
            plan.highlight
              ? "border-accent bg-accent/5 shadow-lg"
              : "border-gray-100 bg-white shadow-sm",
          ]}>
            {plan.badge && (
              <div class="absolute -top-4 left-1/2 -translate-x-1/2 rounded-full bg-accent px-4 py-1 text-xs font-bold uppercase text-white">
                {plan.badge}
              </div>
            )}
            <h3 class="text-center text-lg font-bold text-charcoal">{plan.name}</h3>
            <p class="mt-2 text-center text-4xl font-black text-charcoal">
              {plan.price}<span class="text-base font-normal text-gray-400">/month</span>
            </p>
            <ul class="mt-6 flex-1 space-y-3">
              {plan.features.map((f) => (
                <li class="flex items-center gap-3 text-sm text-gray-600">
                  <svg class="h-4 w-4 flex-shrink-0 text-fresh" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                  {f}
                </li>
              ))}
            </ul>
            <a
              href="/contact/"
              class:list={[
                "mt-8 block rounded-lg py-3 text-center text-sm font-semibold transition-all duration-200",
                plan.highlight
                  ? "bg-accent text-white hover:bg-accent-light hover:shadow-lg hover:shadow-accent/25"
                  : "border-2 border-charcoal text-charcoal hover:bg-charcoal hover:text-white",
              ]}
            >
              Get Started
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <p class="text-sm font-bold uppercase tracking-[0.2em] text-accent">FAQ</p>
        <h2 class="mt-2 text-3xl font-black text-charcoal sm:text-4xl">Frequently asked questions</h2>
      </div>
      <div class="mt-14">
        <FAQ
          items={[
            { question: "Can I migrate from my current booking system?", answer: "Yes. We'll handle the migration for you, including importing your existing client list and upcoming appointments." },
            { question: "Do my clients need to create an account to book?", answer: "No. Clients can book as a guest with just their name and contact details. No app downloads or account creation required." },
            { question: "What happens if I cancel?", answer: "You keep all your data. We'll export everything for you and help you transition if needed. No penalty, no hassle." },
            { question: "Can I take payments through the booking system?", answer: "Yes. We integrate with Stripe for online deposits or full prepayment. You only pay standard Stripe processing fees." },
          ]}
        />
      </div>
    </div>
  </section>

  <CTAStrip
    heading="Stop losing bookings to voicemail"
    text="Let your clients book when it suits them. Setup takes days, not weeks."
  />
</BaseLayout>
