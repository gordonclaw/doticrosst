---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import ServiceCard from "../../components/ServiceCard.astro";
import CTAStrip from "../../components/CTAStrip.astro";
---

<BaseLayout
  title="Services | doticrosst"
  description="Booking systems, website design, SEO, and workflow automation for hairdressers and barbers."
>
  <section class="bg-charcoal py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <Breadcrumb items={[{ label: "Home", href: "/" }, { label: "Services" }]} />
      <div class="mt-4 max-w-2xl">
        <p class="text-sm font-bold uppercase tracking-[0.2em] text-accent-light">Our Services</p>
        <h1 class="mt-3 text-4xl font-black text-white sm:text-5xl">Built for the hair industry</h1>
        <p class="mt-6 text-lg leading-relaxed text-gray-300">
          We don't try to be everything to everyone. We focus on three things
          that make the biggest difference for salons and barbershops -- and we
          do them properly.
        </p>
      </div>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
        <ServiceCard
          title="Booking Systems"
          description="24/7 online booking with no per-appointment fees. Built around how you actually work, not how software companies think you should."
          href="/services/booking-systems/"
          icon='<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>'
        />
        <ServiceCard
          title="Website Design & SEO"
          description="Fast, mobile-first sites that rank locally. We build the kind of site that turns a Google search into a booked appointment."
          href="/services/website-design/"
          icon='<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>'
        />
        <ServiceCard
          title="API Workflows"
          description="Connect your tools, kill the spreadsheets, and stop paying for software you don't need. Open-source where possible, custom where it matters."
          href="/services/api-workflows/"
          icon='<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>'
        />
      </div>
    </div>
  </section>

  <section class="bg-gray-50 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <p class="text-sm font-bold uppercase tracking-[0.2em] text-accent">Why Us</p>
        <h2 class="mt-2 text-3xl font-black text-charcoal sm:text-4xl">Why work with us?</h2>
      </div>
      <div class="mt-14 grid grid-cols-1 gap-8 md:grid-cols-3">
        <div class="group rounded-2xl border border-gray-100 bg-white p-8 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-xl">
          <div class="mb-5 flex h-14 w-14 items-center justify-center rounded-xl bg-fresh/10 text-fresh transition-all duration-300 group-hover:bg-fresh group-hover:text-white">
            <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <path d="M22 11.08V12a10 10 0 11-5.93-9.14" /><polyline points="22 4 12 14.01 9 11.01" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-charcoal">Hair industry focus</h3>
          <p class="mt-2 text-sm leading-relaxed text-gray-500">
            We understand salon workflows, appointment patterns, and what
            clients expect when they search for a haircut.
          </p>
        </div>
        <div class="group rounded-2xl border border-gray-100 bg-white p-8 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-xl">
          <div class="mb-5 flex h-14 w-14 items-center justify-center rounded-xl bg-fresh/10 text-fresh transition-all duration-300 group-hover:bg-fresh group-hover:text-white">
            <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <line x1="12" y1="1" x2="12" y2="23" /><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-charcoal">No monthly SaaS trap</h3>
          <p class="mt-2 text-sm leading-relaxed text-gray-500">
            We build on open-source tools you own. No surprise price hikes, no
            vendor lock-in, no features behind premium tiers.
          </p>
        </div>
        <div class="group rounded-2xl border border-gray-100 bg-white p-8 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-xl">
          <div class="mb-5 flex h-14 w-14 items-center justify-center rounded-xl bg-fresh/10 text-fresh transition-all duration-300 group-hover:bg-fresh group-hover:text-white">
            <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 00-3-3.87" /><path d="M16 3.13a4 4 0 010 7.75" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-charcoal">Ongoing support</h3>
          <p class="mt-2 text-sm leading-relaxed text-gray-500">
            We don't disappear after launch. Affordable monthly plans keep your
            site updated, secure, and performing.
          </p>
        </div>
      </div>
    </div>
  </section>

  <CTAStrip />
</BaseLayout>
