---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import FAQ from "../../components/FAQ.astro";
import CTAStrip from "../../components/CTAStrip.astro";
---

<BaseLayout
  title="Website Design & SEO for Hairdressers & Barbers | doticrosst"
  description="Fast, mobile-first websites that rank locally. Built for salons and barbershops that want to show up when clients search."
>
  <section class="bg-charcoal py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <Breadcrumb
        items={[
          { label: "Home", href: "/" },
          { label: "Services", href: "/services/" },
          { label: "Website Design & SEO" },
        ]}
      />
      <div class="mt-4 max-w-2xl">
        <p class="text-sm font-bold uppercase tracking-[0.2em] text-accent-light">Website Design & SEO</p>
        <h1 class="mt-3 text-4xl font-black text-white sm:text-5xl">
          Websites that turn searches into bookings
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-gray-300">
          Your next client is on their phone right now, searching "barber near
          me" or "hairdresser [your town]". If your website is slow, ugly, or
          invisible on Google -- they'll book with someone else.
        </p>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <p class="text-sm font-bold uppercase tracking-[0.2em] text-accent">What's Included</p>
        <h2 class="mt-2 text-3xl font-black text-charcoal sm:text-4xl">Everything you need</h2>
      </div>
      <div class="mt-14 grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
        {[
          { title: "Mobile-first design", desc: "Over 70% of your visitors are on their phone. Every site we build looks and works perfectly on mobile first.", icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>' },
          { title: "Local SEO setup", desc: "Google Business Profile optimisation, local schema markup, and keyword-targeted content to get you ranking.", icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>' },
          { title: "Lightning fast", desc: "Static-first architecture means your site loads in under a second. Fast sites rank higher and convert better.", icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>' },
          { title: "Service pages that convert", desc: "Dedicated pages for each service you offer -- cuts, colours, styling, beard trims -- each optimised for search.", icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>' },
          { title: "Gallery", desc: "Show off your work. Optimised images that load fast and look sharp on every screen.", icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>' },
          { title: "Booking integration", desc: "Seamless integration with BookJanus or your existing booking system. Every page has a clear path to 'Book Now'.", icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>' },
        ].map((f) => (
          <div class="group rounded-2xl border border-gray-100 bg-white p-8 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-xl">
            <div class="mb-5 flex h-14 w-14 items-center justify-center rounded-xl bg-accent/10 text-accent transition-all duration-300 group-hover:bg-accent group-hover:text-white">
              <div class="h-6 w-6 transition-transform duration-300 group-hover:scale-110" set:html={f.icon} />
            </div>
            <h3 class="text-lg font-bold text-charcoal">{f.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-gray-500">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Portfolio -->
  <section class="bg-gray-50 py-20" id="portfolio">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <p class="text-sm font-bold uppercase tracking-[0.2em] text-accent">Portfolio</p>
        <h2 class="mt-2 text-3xl font-black text-charcoal sm:text-4xl">Recent work</h2>
        <p class="mx-auto mt-4 max-w-md text-gray-500">Sites we've built for salons and barbershops.</p>
      </div>
      <div class="mx-auto mt-14 max-w-md">
        <div class="rounded-2xl border border-gray-100 bg-white p-8 shadow-sm text-center">
          <div class="mx-auto h-48 w-full rounded-xl bg-gray-100"></div>
          <h3 class="mt-6 text-lg font-bold text-charcoal">Coming soon</h3>
          <p class="mt-2 text-sm text-gray-500">Portfolio items will be added as projects launch.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <p class="text-sm font-bold uppercase tracking-[0.2em] text-accent">FAQ</p>
        <h2 class="mt-2 text-3xl font-black text-charcoal sm:text-4xl">Frequently asked questions</h2>
      </div>
      <div class="mt-14">
        <FAQ
          items={[
            { question: "How long does a website build take?", answer: "Most sites go live within 2-3 weeks from kickoff. We work fast because we know the hair industry well and have refined our process." },
            { question: "Do I need to provide content?", answer: "We'll guide you through it. You provide photos of your work and some basic info about your services -- we handle the copywriting and SEO." },
            { question: "Can I update the site myself?", answer: "Yes. We can add a simple content management system for things like gallery updates and blog posts. Or we can handle updates for you on a monthly plan." },
            { question: "What about hosting costs?", answer: "We host on Netlify which is free for the level of traffic most salons get. No hidden hosting fees." },
          ]}
        />
      </div>
    </div>
  </section>

  <CTAStrip
    heading="Ready for a site that actually works?"
    text="Let's build something your clients will love and Google will reward."
  />
</BaseLayout>
