---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import FAQ from "../../components/FAQ.astro";
import CTAStrip from "../../components/CTAStrip.astro";
---

<BaseLayout
  title="Website Design & SEO | doticrosst"
  description="Fast, mobile-first websites with local SEO for small businesses. Built to rank, designed to convert."
>
  <section class="pt-12 pb-32">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <Breadcrumb
        items={[
          { label: "Home", href: "/" },
          { label: "Services", href: "/services/" },
          { label: "Website Design & SEO" },
        ]}
      />
      <div class="mt-4 max-w-2xl">
        <h1 class="mt-3 text-4xl font-bold text-charcoal sm:text-5xl">
          Website Design & SEO Services
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-gray-500">
          Your website is your shopfront. If it's slow, ugly, or invisible on
          Google, you're losing customers to someone who got theirs right. We
          build sites that fix all three.
        </p>
      </div>
    </div>
  </section>

  <!-- What's included -->
  <section class="py-32 border-t border-gray-100" id="local-seo">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h2 class="mt-2 text-3xl font-bold text-charcoal sm:text-4xl">Everything you need to compete online</h2>
      </div>
      <div class="mt-14 grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
        {[
          { title: "Mobile-first design", desc: "Most of your visitors are on their phone. Every site we build looks and works perfectly on mobile first, desktop second.", icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>' },
          { title: "Local SEO", desc: "Google Business Profile optimisation, local schema markup, and keyword-targeted pages to get you ranking in your area.", icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>' },
          { title: "Lightning fast", desc: "Static-first architecture means your site loads in under a second. Fast sites rank higher and convert better.", icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>' },
          { title: "Content that converts", desc: "We write clear, persuasive copy that tells your customers exactly what you do and why they should choose you.", icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>' },
          { title: "Analytics & tracking", desc: "Google Analytics wired up from day one so you can see exactly where your visitors come from and what they do.", icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>' },
          { title: "Ongoing support", desc: "Monthly plans for updates, content changes, and technical maintenance. We don't build it and disappear.", icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>' },
        ].map((f) => (
          <div class="group rounded-2xl border border-gray-100 bg-white p-8 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-xl">
            <div class="mb-5 flex h-14 w-14 items-center justify-center rounded-xl bg-gray-100 text-charcoal transition-all duration-300 group-hover:bg-charcoal group-hover:text-white">
              <div class="h-6 w-6 transition-transform duration-300 group-hover:scale-110" set:html={f.icon} />
            </div>
            <h3 class="text-lg font-bold text-charcoal">{f.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-gray-500">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why your website matters -->
  <section class="py-32 border-t border-gray-100">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-2xl">
        <h2 class="text-2xl font-bold text-charcoal">Why website design matters for small businesses</h2>
        <p class="mt-4 leading-relaxed text-gray-500">
          Your website is your most important marketing tool. When someone searches for what you
          do, your website is the first impression they get. If it is slow, hard to navigate, or
          does not appear on Google, you are losing business to competitors who got their website
          design right. Good website design for small businesses is not about flashy animations
          or trendy layouts. It is about speed, clarity, and making it easy for customers to
          find you and take action.
        </p>
        <p class="mt-4 leading-relaxed text-gray-500">
          SEO for small businesses works best when it is built into the foundation of your site,
          not bolted on afterwards. That means proper heading structure, local schema markup,
          fast page speeds, mobile responsiveness, and content that targets the searches your
          customers actually make. We handle all of this as standard on every website we build,
          so your site is ready to compete in local search results from the moment it goes live.
        </p>
      </div>
    </div>
  </section>

  <!-- Our approach -->
  <section class="py-32 border-t border-gray-100">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h2 class="mt-2 text-3xl font-bold text-charcoal sm:text-4xl">Why we build differently</h2>
      </div>
      <div class="mx-auto mt-14 max-w-2xl space-y-8">
        <div class="flex gap-5">
          <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-lg bg-charcoal text-sm font-bold text-white">1</div>
          <div>
            <h3 class="font-bold text-charcoal">No page builders, no bloat</h3>
            <p class="mt-1 text-sm leading-relaxed text-gray-500">We hand-code every site. No WordPress, no Wix, no drag-and-drop page builders stuffed with plugins that slow everything down.</p>
          </div>
        </div>
        <div class="flex gap-5">
          <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-lg bg-charcoal text-sm font-bold text-white">2</div>
          <div>
            <h3 class="font-bold text-charcoal">You own it</h3>
            <p class="mt-1 text-sm leading-relaxed text-gray-500">Your code, your domain, your content. We build on open tools so you're never locked into a platform or tied to us if you want to move on.</p>
          </div>
        </div>
        <div class="flex gap-5">
          <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-lg bg-charcoal text-sm font-bold text-white">3</div>
          <div>
            <h3 class="font-bold text-charcoal">Free hosting, seriously</h3>
            <p class="mt-1 text-sm leading-relaxed text-gray-500">Our static architecture means hosting is free for the traffic levels most small businesses get. No monthly hosting bill on top of everything else.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-32 border-t border-gray-100">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h2 class="mt-2 text-3xl font-bold text-charcoal sm:text-4xl">Frequently asked questions</h2>
      </div>
      <div class="mt-14">
        <FAQ
          items={[
            { question: "How long does a website build take?", answer: "Most sites go live within 2-3 weeks from kickoff. We work fast because we've refined the process and don't use bloated page builders." },
            { question: "Do I need to provide content?", answer: "We'll guide you through it. You provide photos and some basic info about your business, and we handle the copywriting and SEO." },
            { question: "Can I update the site myself?", answer: "Yes. We can add a simple content management system for things like blog posts and gallery updates. Or we can handle updates for you on a monthly plan." },
            { question: "What does it cost?", answer: "Every project is different but we're upfront about pricing from the first conversation. No hidden fees, no surprise invoices." },
            { question: "What about hosting?", answer: "We host on Netlify which is free for the level of traffic most small businesses get. No hidden hosting fees." },
          ]}
        />
      </div>
    </div>
  </section>

  <CTAStrip
    heading="Ready for a site that actually works?"
    text="Let's build something your customers will love and Google will reward."
    buttonText="Get Your Website Quote"
    buttonHref="/get-started/"
  />
</BaseLayout>
