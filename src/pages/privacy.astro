---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
---

<BaseLayout title="Privacy Policy | doticrosst" noindex={true}>
  <section class="bg-charcoal py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <Breadcrumb items={[{ label: "Home", href: "/" }, { label: "Privacy Policy" }]} />
      <h1 class="mt-4 text-4xl font-black text-white sm:text-5xl">Privacy Policy</h1>
      <p class="mt-3 text-sm text-gray-400">Last updated: March 2026</p>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <div class="space-y-10">
        <div>
          <h2 class="text-xl font-bold text-charcoal">Who we are</h2>
          <p class="mt-3 leading-relaxed text-gray-500">
            doticrosst is a digital agency operated from the United Kingdom. Our website address is https://doticrosst.com.
          </p>
        </div>
        <div>
          <h2 class="text-xl font-bold text-charcoal">What data we collect</h2>
          <p class="mt-3 leading-relaxed text-gray-500">
            When you use our contact form, we collect your name, email address, and the contents of your message. This data is processed by Netlify Forms and stored securely.
          </p>
        </div>
        <div>
          <h2 class="text-xl font-bold text-charcoal">How we use your data</h2>
          <p class="mt-3 leading-relaxed text-gray-500">
            We use the information you provide solely to respond to your enquiry and to discuss potential services. We do not sell, rent, or share your personal data with third parties.
          </p>
        </div>
        <div>
          <h2 class="text-xl font-bold text-charcoal">Analytics</h2>
          <p class="mt-3 leading-relaxed text-gray-500">
            We may use analytics tools to understand how visitors use our website. This data is anonymised and used only to improve our services.
          </p>
        </div>
        <div>
          <h2 class="text-xl font-bold text-charcoal">Your rights</h2>
          <p class="mt-3 leading-relaxed text-gray-500">
            Under GDPR, you have the right to access, correct, or delete your personal data. Contact us at craig@doticrosst.com to make a request.
          </p>
        </div>
        <div>
          <h2 class="text-xl font-bold text-charcoal">Contact</h2>
          <p class="mt-3 leading-relaxed text-gray-500">
            For any privacy-related questions, email us at
            <a href="mailto:craig@doticrosst.com" class="font-medium text-accent hover:text-accent-light">craig@doticrosst.com</a>.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
