---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
---

<BaseLayout title="Terms of Service | doticrosst" noindex={true}>
  <section class="bg-charcoal py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <Breadcrumb items={[{ label: "Home", href: "/" }, { label: "Terms of Service" }]} />
      <h1 class="mt-4 text-4xl font-black text-white sm:text-5xl">Terms of Service</h1>
      <p class="mt-3 text-sm text-gray-400">Last updated: March 2026</p>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <div class="space-y-10">
        <div>
          <h2 class="text-xl font-bold text-charcoal">Agreement</h2>
          <p class="mt-3 leading-relaxed text-gray-500">
            By accessing doticrosst.com, you agree to these terms. If you do not agree, please do not use this website.
          </p>
        </div>
        <div>
          <h2 class="text-xl font-bold text-charcoal">Services</h2>
          <p class="mt-3 leading-relaxed text-gray-500">
            doticrosst provides digital agency services including website design, booking system development, SEO, and workflow automation. Specific terms for individual projects are agreed in writing before work begins.
          </p>
        </div>
        <div>
          <h2 class="text-xl font-bold text-charcoal">Intellectual property</h2>
          <p class="mt-3 leading-relaxed text-gray-500">
            Upon full payment, clients own the deliverables created for their project. doticrosst retains the right to use anonymised examples of work in our portfolio unless otherwise agreed.
          </p>
        </div>
        <div>
          <h2 class="text-xl font-bold text-charcoal">Limitation of liability</h2>
          <p class="mt-3 leading-relaxed text-gray-500">
            doticrosst provides services on an "as is" basis. We are not liable for any indirect or consequential damages arising from use of our services or this website.
          </p>
        </div>
        <div>
          <h2 class="text-xl font-bold text-charcoal">Changes</h2>
          <p class="mt-3 leading-relaxed text-gray-500">
            We may update these terms from time to time. Continued use of the website constitutes acceptance of any changes.
          </p>
        </div>
        <div>
          <h2 class="text-xl font-bold text-charcoal">Contact</h2>
          <p class="mt-3 leading-relaxed text-gray-500">
            Questions about these terms? Email
            <a href="mailto:hello@doticrosst.com" class="font-medium text-accent hover:text-accent-light">hello@doticrosst.com</a>.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
