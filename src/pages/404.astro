---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Page Not Found | doticrosst" noindex={true}>
  <section class="flex min-h-[70vh] items-center justify-center">
    <div class="px-4 text-center">
      <h1 class="text-8xl font-bold text-charcoal sm:text-9xl">404 Page Not Found</h1>
      <p class="mt-4 text-lg text-gray-400">
        That page doesn't exist. It might have been moved or you may have mistyped the URL.
      </p>
      <a
        href="/"
        class="mt-8 inline-flex rounded-full bg-charcoal px-7 py-3.5 text-sm font-semibold text-white transition-all duration-200 hover:-translate-y-0.5 hover:bg-charcoal-light"
      >
        Back to Home
      </a>
    </div>
  </section>
</BaseLayout>
