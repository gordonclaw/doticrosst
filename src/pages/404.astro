---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Page Not Found | doticrosst" noindex={true}>
  <section class="not-found">
    <div class="container">
      <h1>404</h1>
      <p>That page doesn't exist. It might have been moved or you may have mistyped the URL.</p>
      <a href="/" class="btn btn-primary">Back to Home</a>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
    text-align: center;
  }

  h1 {
    font-size: 5rem;
    color: var(--primary);
    margin-bottom: var(--space-md);
  }

  p {
    color: var(--text-light);
    font-size: 1.1rem;
    margin: 0 auto var(--space-xl);
  }
</style>
