---
import BaseLayout from "../layouts/BaseLayout.astro";
import ServiceCard from "../components/ServiceCard.astro";
import CTAStrip from "../components/CTAStrip.astro";
---

<BaseLayout title="doticrosst | Digital Agency for Hairdressers & Barbers">
  <!-- Hero -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-content">
        <p class="hero-tag">Digital Agency for Hair Professionals</p>
        <h1>You cut hair. We handle everything else.</h1>
        <p class="hero-sub">
          Booking systems, websites, SEO, and smart automation -- built
          specifically for hairdressers and barbers who want to grow without the
          tech headache.
        </p>
        <div class="hero-actions">
          <a href="/contact/" class="btn btn-primary">Book a Free Call</a>
          <a href="/services/" class="btn btn-secondary">See Our Services</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="section section-alt">
    <div class="container">
      <div class="stats-grid">
        <div class="stat">
          <span class="stat-number" data-target="50">0</span>
          <span class="stat-suffix">+</span>
          <p>Salons & Barbershops Served</p>
        </div>
        <div class="stat">
          <span class="stat-number" data-target="98">0</span>
          <span class="stat-suffix">%</span>
          <p>Client Retention Rate</p>
        </div>
        <div class="stat">
          <span class="stat-number" data-target="30">0</span>
          <span class="stat-suffix">hrs</span>
          <p>Saved Per Month on Average</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="section" id="services">
    <div class="container">
      <div class="section-header">
        <h2>What we do</h2>
        <p>
          Three core services, one goal: let you focus on your clients while we
          take care of the digital side.
        </p>
      </div>
      <div class="grid-3">
        <ServiceCard
          title="Booking Systems"
          description="Online booking that works around your schedule. Clients book 24/7, you get fewer no-shows, and no monthly SaaS fees eating your margin."
          href="/services/booking-systems/"
          icon='<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>'
        />
        <ServiceCard
          title="Website Design & SEO"
          description="Fast, mobile-first websites that rank locally. Your next client is searching right now -- make sure they find you, not a competitor."
          href="/services/website-design/"
          icon='<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>'
        />
        <ServiceCard
          title="API Workflows & Automation"
          description="Connect your tools, ditch the spreadsheets, and stop paying for software you don't need. We wire up the systems that run your business."
          href="/services/api-workflows/"
          icon='<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>'
        />
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="section section-alt" id="how-it-works">
    <div class="container">
      <div class="section-header">
        <h2>How it works</h2>
        <p>Simple process, real results.</p>
      </div>
      <div class="steps">
        <div class="step">
          <div class="step-number">1</div>
          <h3>Discovery call</h3>
          <p>
            We learn about your business, your pain points, and what you
            actually need -- no upselling.
          </p>
        </div>
        <div class="step">
          <div class="step-number">2</div>
          <h3>We build it</h3>
          <p>
            Your site, booking system, or workflow goes live in days, not months.
            You review everything before launch.
          </p>
        </div>
        <div class="step">
          <div class="step-number">3</div>
          <h3>You grow</h3>
          <p>
            More bookings, less admin, better online presence. We stick around
            for ongoing support.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials placeholder -->
  <section class="section" id="testimonials">
    <div class="container">
      <div class="section-header">
        <h2>What our clients say</h2>
      </div>
      <div class="grid-2 testimonial-grid">
        <blockquote class="testimonial">
          <p>
            "I was paying for three different apps to manage my bookings, website, and
            marketing emails. doticrosst replaced all of them and it actually works better."
          </p>
          <footer>
            <strong>Sarah M.</strong>
            <span>Salon Owner, Manchester</span>
          </footer>
        </blockquote>
        <blockquote class="testimonial">
          <p>
            "My website went from nowhere to the first page for 'barber near me' in six
            weeks. The phone hasn't stopped."
          </p>
          <footer>
            <strong>James T.</strong>
            <span>Barbershop Owner, Edinburgh</span>
          </footer>
        </blockquote>
      </div>
    </div>
  </section>

  <CTAStrip />
</BaseLayout>

<script>
  // Animated counters
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          const target = parseInt(el.dataset.target || "0", 10);
          let current = 0;
          const step = Math.ceil(target / 40);
          const interval = setInterval(() => {
            current += step;
            if (current >= target) {
              current = target;
              clearInterval(interval);
            }
            el.textContent = String(current);
          }, 30);
          observer.unobserve(el);
        }
      });
    },
    { threshold: 0.5 }
  );

  document.querySelectorAll(".stat-number").forEach((el) => observer.observe(el));
</script>

<style>
  /* Hero */
  .hero {
    padding: var(--space-4xl) 0;
    background: linear-gradient(135deg, var(--bg) 0%, var(--primary-light) 100%);
  }

  .hero-content {
    max-width: 680px;
  }

  .hero-tag {
    display: inline-block;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--primary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-md);
  }

  .hero h1 {
    margin-bottom: var(--space-lg);
  }

  .hero-sub {
    font-size: 1.15rem;
    color: var(--text-light);
    line-height: 1.7;
    margin-bottom: var(--space-xl);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
  }

  /* Stats */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
    text-align: center;
  }

  .stat-number {
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--primary);
    line-height: 1;
  }

  .stat-suffix {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--primary);
  }

  .stat p {
    margin: var(--space-sm) auto 0;
    color: var(--text-light);
    font-size: 0.9rem;
  }

  /* Steps */
  .steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
  }

  .step {
    text-align: center;
  }

  .step-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    background: var(--primary);
    color: var(--text-inv);
    font-weight: 700;
    font-size: 1.25rem;
    border-radius: 50%;
    margin-bottom: var(--space-md);
  }

  .step h3 {
    margin-bottom: var(--space-sm);
  }

  .step p {
    color: var(--text-light);
    font-size: 0.95rem;
    margin: 0 auto;
  }

  /* Testimonials */
  .testimonial {
    background: var(--bg-alt);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    border-left: 4px solid var(--primary);
  }

  .testimonial p {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--text);
    font-style: italic;
    max-width: none;
  }

  .testimonial footer {
    margin-top: var(--space-md);
  }

  .testimonial footer strong {
    display: block;
    font-style: normal;
  }

  .testimonial footer span {
    font-size: 0.85rem;
    color: var(--text-light);
    font-style: normal;
  }

  @media (max-width: 640px) {
    .stats-grid,
    .steps {
      grid-template-columns: 1fr;
    }
  }
</style>
