---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTAStrip from "../components/CTAStrip.astro";
import FAQ from "../components/FAQ.astro";

const faqItems = [
  { question: "Why not just use Wix or Squarespace?", answer: "They're fine for a basic placeholder but they're slow, bloated with features you don't need, and you're paying a monthly fee forever. Our websites load in under a second, score 100 on Lighthouse, and hosting is free. You pay for the build, you own the site." },
  { question: "How is hosting free?", answer: "We build on static architecture and host on Netlify. For the traffic levels most small businesses get, hosting costs nothing. No monthly bill on top of everything else." },
  { question: "Do I own my website?", answer: "Yes. Your code, your domain, your content. We build on open tools so you're never locked into a platform or tied to us. If you want to move on, everything is yours." },
  { question: "How long does a website take to build?", answer: "Most sites go live within 2-3 weeks from when we start. We work fast because we've refined the process and don't use bloated page builders." },
  { question: "What does a website cost?", answer: "Every project is different but we're upfront about pricing from the first conversation. Fill in our scoping form and we'll come back with a clear quote within one working day. No hidden fees." },
];
---

<BaseLayout
  title="Website Design & SEO for Small Businesses | doticrosst"
  description="Fast, mobile-first websites for small businesses. Local SEO, free hosting, no page builders. Specialist division for hairdressers and barbers."
>
  <!-- Hero -->
  <section class="pb-32 pt-24 sm:pt-32 sm:pb-40">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1 class="text-5xl font-bold leading-[1.1] text-charcoal sm:text-6xl lg:text-7xl">
          Websites that work harder than yours does right now.
        </h1>
        <p class="mt-8 max-w-xl text-lg leading-relaxed text-gray-500">
          We build fast, hand-coded websites for small businesses. Sub-second load times, local SEO from day one, and free hosting. No page builders, no monthly platform fees.
        </p>
        <div class="mt-10 flex items-center gap-6">
          <a href="/get-started/" class="rounded-full bg-charcoal px-7 py-3.5 text-sm font-medium text-white transition-all duration-200 hover:bg-charcoal-light">
            Get a free quote
          </a>
          <a href="/services/" class="text-sm text-gray-500 underline underline-offset-4 decoration-gray-300 transition-colors duration-200 hover:text-charcoal hover:decoration-charcoal">
            How we work
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Metrics strip -->
  <section class="border-y border-gray-100 py-16">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 gap-12 sm:grid-cols-4">
        <div>
          <p class="text-4xl font-bold tracking-tight text-charcoal">100</p>
          <p class="mt-2 text-sm text-gray-400">Lighthouse score</p>
        </div>
        <div>
          <p class="text-4xl font-bold tracking-tight text-charcoal">&lt;1s</p>
          <p class="mt-2 text-sm text-gray-400">Page load</p>
        </div>
        <div>
          <p class="text-4xl font-bold tracking-tight text-charcoal">&pound;0</p>
          <p class="mt-2 text-sm text-gray-400">Monthly hosting</p>
        </div>
        <div>
          <p class="text-4xl font-bold tracking-tight text-charcoal">2-3wk</p>
          <p class="mt-2 text-sm text-gray-400">To launch</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Why it matters -->
  <section class="py-32">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-16 lg:grid-cols-2">
        <h2 class="text-3xl font-bold leading-tight text-charcoal sm:text-4xl lg:text-5xl">
          Your website is your hardest working employee.
        </h2>
        <div class="space-y-6">
          <p class="text-lg leading-relaxed text-gray-500">
            It works 24 hours a day, 7 days a week. When someone searches for your business at 11pm on a Sunday, your website is the one answering the door.
          </p>
          <p class="leading-relaxed text-gray-500">
            If it's slow, outdated, or invisible on Google, you're losing customers to businesses with better websites. Every site we deliver is hand-coded, loads in under a second, scores 100 on Google Lighthouse, and is optimised for local search from day one.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="bg-charcoal py-32">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-white sm:text-4xl">What we do</h2>
      <div class="mt-16 grid gap-px bg-white/10 sm:grid-cols-3">
        <div class="bg-charcoal p-10">
          <h3 class="text-lg font-semibold text-white">Website Design</h3>
          <p class="mt-4 text-sm leading-relaxed text-gray-400">
            Clean, modern websites built on fast static architecture. Mobile-first, accessible, and designed to convert visitors into customers.
          </p>
          <a href="/services/website-design/" class="mt-6 inline-block text-sm text-gray-500 underline underline-offset-4 decoration-gray-600 transition-colors hover:text-white hover:decoration-white">Learn more</a>
        </div>
        <div class="bg-charcoal p-10">
          <h3 class="text-lg font-semibold text-white">Local SEO</h3>
          <p class="mt-4 text-sm leading-relaxed text-gray-400">
            Google Business Profile setup, local schema markup, keyword-targeted pages. We make your website work for local search.
          </p>
          <a href="/services/website-design/#local-seo" class="mt-6 inline-block text-sm text-gray-500 underline underline-offset-4 decoration-gray-600 transition-colors hover:text-white hover:decoration-white">Learn more</a>
        </div>
        <div class="bg-charcoal p-10">
          <h3 class="text-lg font-semibold text-white">Ongoing Support</h3>
          <p class="mt-4 text-sm leading-relaxed text-gray-400">
            We don't disappear after launch. Monthly plans for updates, content changes, performance monitoring, and technical fixes.
          </p>
          <a href="/get-started/" class="mt-6 inline-block text-sm text-gray-500 underline underline-offset-4 decoration-gray-600 transition-colors hover:text-white hover:decoration-white">Learn more</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Hair & Barber specialism -->
  <section class="py-32">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-16 lg:grid-cols-2 items-start">
        <div>
          <p class="text-sm font-medium text-gray-400">Specialist division</p>
          <h2 class="mt-3 text-3xl font-bold leading-tight text-charcoal sm:text-4xl lg:text-5xl">
            Websites for hairdressers &amp; barbers.
          </h2>
          <p class="mt-6 text-lg leading-relaxed text-gray-500">
            We run a dedicated division for the hair industry because we know the business inside out. Appointment patterns, walk-in culture, the importance of a strong gallery, and what your clients actually search for.
          </p>
          <ul class="mt-8 space-y-4">
            {[
              "Service pages optimised for local search",
              "Gallery layouts built for showcasing cuts and colour",
              "Integration with your booking system",
              "Google Business Profile optimisation",
              "Mobile-first, because 70%+ of your clients search on their phone",
            ].map((item) => (
              <li class="flex items-start gap-3 text-sm text-gray-600">
                <span class="mt-1 block h-1.5 w-1.5 rounded-full bg-charcoal flex-shrink-0"></span>
                {item}
              </li>
            ))}
          </ul>
          <a
            href="/services/hair-barber/"
            class="mt-10 inline-block rounded-full bg-charcoal px-7 py-3.5 text-sm font-medium text-white transition-all duration-200 hover:bg-charcoal-light"
          >
            Hair &amp; barber services
          </a>
        </div>

        <!-- Portfolio: Hair by Dom -->
        <div class="lg:mt-16">
          <a href="https://hairbydom.co.uk" target="_blank" rel="noopener noreferrer" class="group block">
            <div class="overflow-hidden rounded-2xl border border-gray-100 bg-white transition-all duration-300 group-hover:-translate-y-1 group-hover:shadow-xl">
              <div class="relative bg-charcoal p-6">
                <div class="flex items-center gap-2 mb-4">
                  <div class="h-2 w-2 rounded-full bg-gray-600"></div>
                  <div class="h-2 w-2 rounded-full bg-gray-600"></div>
                  <div class="h-2 w-2 rounded-full bg-gray-600"></div>
                  <span class="ml-2 text-[10px] text-gray-500">hairbydom.co.uk</span>
                </div>
                <div class="space-y-3">
                  <div class="h-3 w-24 rounded bg-white/15"></div>
                  <div class="h-6 w-48 rounded bg-white/25"></div>
                  <div class="h-3 w-64 rounded bg-white/10"></div>
                  <div class="mt-4 flex gap-2">
                    <div class="h-8 w-20 rounded-full bg-white/20"></div>
                    <div class="h-8 w-20 rounded-full bg-white/10"></div>
                  </div>
                </div>
              </div>
              <div class="p-6">
                <h3 class="font-semibold text-charcoal">Hair by Dom</h3>
                <p class="mt-1 text-sm text-gray-400">Dunfermline, Fife</p>
                <p class="mt-3 text-sm leading-relaxed text-gray-500">
                  Mobile-first build, sub-second load times, local SEO targeting West Fife. Booking and WhatsApp integration.
                </p>
              </div>
            </div>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="border-t border-gray-100 py-32">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-charcoal sm:text-4xl">How it works</h2>
      <div class="mt-16 grid gap-16 sm:grid-cols-3">
        <div>
          <p class="text-5xl font-bold text-gray-200">01</p>
          <h3 class="mt-4 text-lg font-semibold text-charcoal">Tell us about your business</h3>
          <p class="mt-3 text-sm leading-relaxed text-gray-500">
            Fill in our scoping form. Takes about two minutes and gives us everything we need to quote you.
          </p>
        </div>
        <div>
          <p class="text-5xl font-bold text-gray-200">02</p>
          <h3 class="mt-4 text-lg font-semibold text-charcoal">We build your website</h3>
          <p class="mt-3 text-sm leading-relaxed text-gray-500">
            Your site goes live in 2-3 weeks. Hand-coded, mobile-first, SEO-ready. You review everything before launch.
          </p>
        </div>
        <div>
          <p class="text-5xl font-bold text-gray-200">03</p>
          <h3 class="mt-4 text-lg font-semibold text-charcoal">Your website works for you</h3>
          <p class="mt-3 text-sm leading-relaxed text-gray-500">
            More traffic, more enquiries, a stronger first impression. Your website works around the clock.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-gray-100 py-32">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-16 lg:grid-cols-2">
        <h2 class="text-3xl font-bold text-charcoal sm:text-4xl">
          Common questions
        </h2>
        <FAQ items={faqItems} />
      </div>
    </div>
  </section>

  <CTAStrip
    heading="Ready for a website that works?"
    text="Fill in our scoping form and get a clear quote within one working day. No obligation."
    buttonText="Get a free quote"
    buttonHref="/get-started/"
  />
</BaseLayout>
