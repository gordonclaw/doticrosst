---
import BaseLayout from "../layouts/BaseLayout.astro";
import ServiceCard from "../components/ServiceCard.astro";
import CTAStrip from "../components/CTAStrip.astro";
---

<BaseLayout title="doticrosst | Website Design & SEO Agency">
  <!-- Hero -->
  <section class="relative overflow-hidden bg-charcoal pt-20 pb-20">
    <div class="absolute inset-0 bg-gradient-to-br from-accent/15 via-charcoal to-charcoal-light"></div>
    <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2">
        <!-- Left: copy -->
        <div>
          <p class="text-sm font-bold uppercase tracking-[0.25em] text-accent-light">
            Website Design & SEO Agency
          </p>
          <h1 class="mt-4 text-4xl font-black leading-tight text-white sm:text-5xl">
            Websites that work<br />
            <span class="text-accent-light">as hard as you do.</span>
          </h1>
          <p class="mt-6 max-w-lg text-lg leading-relaxed text-gray-300">
            Fast, mobile-first websites and local SEO for small businesses.
            No bloat, no lock-in, no jargon. Just a site that ranks, converts,
            and pays for itself.
          </p>
          <div class="mt-8 flex flex-wrap gap-4">
            <a
              href="/contact/"
              class="rounded-lg bg-accent px-7 py-3.5 text-sm font-semibold text-white transition-all duration-200 hover:-translate-y-0.5 hover:bg-accent-light hover:shadow-lg hover:shadow-accent/25"
            >
              Book a Free Call
            </a>
            <a
              href="/services/"
              class="rounded-lg border-2 border-white/20 px-7 py-3.5 text-sm font-semibold text-white transition-all duration-200 hover:border-accent-light hover:text-accent-light"
            >
              See Our Services
            </a>
          </div>
          <div class="mt-8 flex flex-wrap gap-5 text-sm text-gray-400">
            {["No contracts", "No page builders", "Free hosting", "You own it"].map((t) => (
              <span class="flex items-center gap-1.5">
                <svg class="h-4 w-4 text-accent-light" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                {t}
              </span>
            ))}
          </div>
        </div>

        <!-- Right: stats / proof -->
        <div class="hidden lg:block">
          <div class="grid grid-cols-2 gap-4">
            <div class="rounded-2xl border border-white/10 bg-white/5 p-6 backdrop-blur-sm">
              <p class="text-3xl font-black text-white">100</p>
              <p class="mt-1 text-xs text-gray-400">Lighthouse score</p>
            </div>
            <div class="rounded-2xl border border-white/10 bg-white/5 p-6 backdrop-blur-sm">
              <p class="text-3xl font-black text-white">&lt;1s</p>
              <p class="mt-1 text-xs text-gray-400">Page load time</p>
            </div>
            <div class="rounded-2xl border border-white/10 bg-white/5 p-6 backdrop-blur-sm">
              <p class="text-3xl font-black text-accent-light">&pound;0</p>
              <p class="mt-1 text-xs text-gray-400">Monthly hosting</p>
            </div>
            <div class="rounded-2xl border border-white/10 bg-white/5 p-6 backdrop-blur-sm">
              <p class="text-3xl font-black text-white">2-3</p>
              <p class="mt-1 text-xs text-gray-400">Weeks to launch</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What we do -->
  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <p class="text-sm font-bold uppercase tracking-[0.2em] text-accent">What We Do</p>
        <h2 class="mt-2 text-3xl font-black text-charcoal sm:text-4xl">Your online presence, sorted</h2>
        <p class="mx-auto mt-4 max-w-xl text-gray-500">
          We design and build websites that look sharp on every device, load fast,
          and show up when your customers search.
        </p>
      </div>
      <div class="mt-14 grid grid-cols-1 gap-8 md:grid-cols-3">
        <ServiceCard
          title="Website Design"
          description="Clean, modern sites built on fast static architecture. Mobile-first, accessible, and designed to convert visitors into customers."
          href="/services/website-design/"
          icon='<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>'
        />
        <ServiceCard
          title="Local SEO"
          description="Google Business Profile setup, local schema markup, keyword-targeted pages, and content that gets you ranking in your area."
          href="/services/website-design/"
          icon='<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>'
        />
        <ServiceCard
          title="Ongoing Support"
          description="We don't disappear after launch. Monthly plans for updates, content changes, performance monitoring, and technical fixes."
          href="/contact/"
          icon='<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>'
        />
      </div>
    </div>
  </section>

  <!-- Hair & Barber specialism -->
  <section class="bg-gray-50 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2">
        <div>
          <p class="text-sm font-bold uppercase tracking-[0.2em] text-accent">Specialist Division</p>
          <h2 class="mt-2 text-3xl font-black text-charcoal sm:text-4xl">
            Websites for hairdressers & barbers
          </h2>
          <p class="mt-4 leading-relaxed text-gray-500">
            We run a dedicated division for the hair industry. We know the
            business -- appointment patterns, walk-in vs. booked clients, the
            importance of showing off your work. Your website should reflect
            your skill, not a generic template.
          </p>
          <ul class="mt-6 space-y-3">
            {[
              "Service pages optimised for local search",
              "Gallery layouts built for showcasing cuts and colour",
              "Integration with your booking system",
              "Google Business Profile optimisation",
              "Mobile-first -- because 70%+ of your clients search on their phone",
            ].map((item) => (
              <li class="flex items-start gap-3 text-sm text-gray-600">
                <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-fresh" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
          <a
            href="/services/hair-barber/"
            class="mt-8 inline-flex items-center gap-2 rounded-lg bg-accent px-7 py-3.5 text-sm font-semibold text-white transition-all duration-200 hover:-translate-y-0.5 hover:bg-accent-light hover:shadow-lg hover:shadow-accent/25"
          >
            Learn more
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
            </svg>
          </a>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="space-y-4">
            <div class="h-48 rounded-2xl bg-gray-200"></div>
            <div class="h-32 rounded-2xl bg-gray-200"></div>
          </div>
          <div class="space-y-4 pt-8">
            <div class="h-32 rounded-2xl bg-gray-200"></div>
            <div class="h-48 rounded-2xl bg-gray-200"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="bg-white py-20" id="how-it-works">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <p class="text-sm font-bold uppercase tracking-[0.2em] text-accent">How It Works</p>
        <h2 class="mt-2 text-3xl font-black text-charcoal sm:text-4xl">Simple process, real results</h2>
      </div>
      <div class="mt-14 grid grid-cols-1 gap-12 md:grid-cols-3">
        <div class="text-center">
          <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-accent text-xl font-bold text-white">
            1
          </div>
          <h3 class="mt-5 text-lg font-bold text-charcoal">Discovery call</h3>
          <p class="mt-2 text-sm leading-relaxed text-gray-500">
            We learn about your business, your customers, and what you actually
            need. No upselling, no jargon.
          </p>
        </div>
        <div class="text-center">
          <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-accent text-xl font-bold text-white">
            2
          </div>
          <h3 class="mt-5 text-lg font-bold text-charcoal">We build it</h3>
          <p class="mt-2 text-sm leading-relaxed text-gray-500">
            Your site goes live in weeks, not months. You review everything
            before launch and we don't stop until you're happy.
          </p>
        </div>
        <div class="text-center">
          <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-accent text-xl font-bold text-white">
            3
          </div>
          <h3 class="mt-5 text-lg font-bold text-charcoal">You grow</h3>
          <p class="mt-2 text-sm leading-relaxed text-gray-500">
            More traffic, more enquiries, a better first impression. We stick
            around for ongoing support.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="bg-charcoal py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-10 text-center sm:grid-cols-3">
        <div>
          <div class="flex items-baseline justify-center gap-1">
            <span class="stat-number text-4xl font-black text-white sm:text-5xl" data-target="50">0</span>
            <span class="text-2xl font-bold text-accent-light">+</span>
          </div>
          <p class="mt-2 text-sm text-gray-400">Websites Delivered</p>
        </div>
        <div>
          <div class="flex items-baseline justify-center gap-1">
            <span class="stat-number text-4xl font-black text-white sm:text-5xl" data-target="98">0</span>
            <span class="text-2xl font-bold text-accent-light">%</span>
          </div>
          <p class="mt-2 text-sm text-gray-400">Client Retention Rate</p>
        </div>
        <div>
          <div class="flex items-baseline justify-center gap-1">
            <span class="stat-number text-4xl font-black text-white sm:text-5xl" data-target="100">0</span>
            <span class="text-2xl font-bold text-accent-light">/100</span>
          </div>
          <p class="mt-2 text-sm text-gray-400">Average Lighthouse Score</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="bg-gray-50 py-20" id="testimonials">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <p class="text-sm font-bold uppercase tracking-[0.2em] text-accent">Testimonials</p>
        <h2 class="mt-2 text-3xl font-black text-charcoal sm:text-4xl">What our clients say</h2>
      </div>
      <div class="mt-14 grid grid-cols-1 gap-8 md:grid-cols-2">
        <blockquote class="rounded-2xl border border-gray-100 bg-white p-8 shadow-sm">
          <div class="flex gap-1 text-energy">
            {Array(5).fill(null).map(() => (
              <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <p class="mt-4 leading-relaxed text-gray-600 italic">
            "We'd been putting off getting a proper website for years. doticrosst made
            it painless -- the site was live in two weeks and we started getting enquiries
            straight away."
          </p>
          <footer class="mt-5">
            <p class="font-semibold text-charcoal">Sarah M.</p>
            <p class="text-sm text-gray-400">Salon Owner, Manchester</p>
          </footer>
        </blockquote>
        <blockquote class="rounded-2xl border border-gray-100 bg-white p-8 shadow-sm">
          <div class="flex gap-1 text-energy">
            {Array(5).fill(null).map(() => (
              <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <p class="mt-4 leading-relaxed text-gray-600 italic">
            "My old site was invisible on Google. Six weeks after launch the new one
            was on the first page for 'barber near me'. The phone hasn't stopped."
          </p>
          <footer class="mt-5">
            <p class="font-semibold text-charcoal">James T.</p>
            <p class="text-sm text-gray-400">Barbershop Owner, Edinburgh</p>
          </footer>
        </blockquote>
      </div>
    </div>
  </section>

  <CTAStrip />
</BaseLayout>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          const target = parseInt(el.dataset.target || "0", 10);
          let current = 0;
          const step = Math.ceil(target / 40);
          const interval = setInterval(() => {
            current += step;
            if (current >= target) {
              current = target;
              clearInterval(interval);
            }
            el.textContent = String(current);
          }, 30);
          observer.unobserve(el);
        }
      });
    },
    { threshold: 0.5 }
  );

  document.querySelectorAll(".stat-number").forEach((el) => observer.observe(el));
</script>
