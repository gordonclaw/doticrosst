---
import BaseLayout from "../layouts/BaseLayout.astro";
import ServiceCard from "../components/ServiceCard.astro";
import CTAStrip from "../components/CTAStrip.astro";
---

<BaseLayout title="doticrosst | Digital Agency for Hairdressers & Barbers">
  <!-- Hero -->
  <section class="relative flex min-h-[85vh] items-center bg-charcoal">
    <div class="absolute inset-0 bg-gradient-to-br from-accent/15 via-charcoal to-charcoal-light"></div>
    <div class="relative z-10 mx-auto max-w-7xl px-4 py-24 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <p class="text-sm font-bold uppercase tracking-[0.25em] text-accent-light">
          Digital Agency for Hair Professionals
        </p>
        <h1 class="mt-4 text-4xl font-black leading-tight text-white sm:text-5xl lg:text-6xl">
          You cut hair.<br />
          <span class="text-accent-light">We handle everything else.</span>
        </h1>
        <p class="mt-6 max-w-lg text-lg leading-relaxed text-gray-300">
          Booking systems, websites, SEO, and smart automation -- built
          specifically for hairdressers and barbers who want to grow without the
          tech headache.
        </p>
        <div class="mt-10 flex flex-wrap gap-4">
          <a
            href="/contact/"
            class="rounded-lg bg-accent px-7 py-3.5 text-sm font-semibold text-white transition-all duration-200 hover:-translate-y-0.5 hover:bg-accent-light hover:shadow-lg hover:shadow-accent/25"
          >
            Book a Free Call
          </a>
          <a
            href="/services/"
            class="rounded-lg border-2 border-white/20 px-7 py-3.5 text-sm font-semibold text-white transition-all duration-200 hover:border-accent-light hover:text-accent-light"
          >
            See Our Services
          </a>
        </div>
      </div>
    </div>
    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2">
      <svg class="h-6 w-6 animate-bounce text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M12 5v14M5 12l7 7 7-7" />
      </svg>
    </div>
  </section>

  <!-- Stats -->
  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-10 text-center sm:grid-cols-3">
        <div>
          <div class="flex items-baseline justify-center gap-1">
            <span class="stat-number text-4xl font-black text-charcoal sm:text-5xl" data-target="50">0</span>
            <span class="text-2xl font-bold text-accent">+</span>
          </div>
          <p class="mt-2 text-sm text-gray-500">Salons & Barbershops Served</p>
        </div>
        <div>
          <div class="flex items-baseline justify-center gap-1">
            <span class="stat-number text-4xl font-black text-charcoal sm:text-5xl" data-target="98">0</span>
            <span class="text-2xl font-bold text-accent">%</span>
          </div>
          <p class="mt-2 text-sm text-gray-500">Client Retention Rate</p>
        </div>
        <div>
          <div class="flex items-baseline justify-center gap-1">
            <span class="stat-number text-4xl font-black text-charcoal sm:text-5xl" data-target="30">0</span>
            <span class="text-2xl font-bold text-accent">hrs</span>
          </div>
          <p class="mt-2 text-sm text-gray-500">Saved Per Month on Average</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="bg-gray-50 py-20" id="services">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <p class="text-sm font-bold uppercase tracking-[0.2em] text-accent">What We Do</p>
        <h2 class="mt-2 text-3xl font-black text-charcoal sm:text-4xl">Three services, one goal</h2>
        <p class="mx-auto mt-4 max-w-xl text-gray-500">
          Let you focus on your clients while we take care of the digital side.
        </p>
      </div>
      <div class="mt-14 grid grid-cols-1 gap-8 md:grid-cols-3">
        <ServiceCard
          title="Booking Systems"
          description="Online booking that works around your schedule. Clients book 24/7, fewer no-shows, and no monthly SaaS fees eating your margin."
          href="/services/booking-systems/"
          icon='<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>'
        />
        <ServiceCard
          title="Website Design & SEO"
          description="Fast, mobile-first websites that rank locally. Your next client is searching right now -- make sure they find you."
          href="/services/website-design/"
          icon='<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>'
        />
        <ServiceCard
          title="API Workflows"
          description="Connect your tools, ditch the spreadsheets, and stop paying for software you don't need. Open-source where it matters."
          href="/services/api-workflows/"
          icon='<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>'
        />
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="bg-white py-20" id="how-it-works">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <p class="text-sm font-bold uppercase tracking-[0.2em] text-accent">How It Works</p>
        <h2 class="mt-2 text-3xl font-black text-charcoal sm:text-4xl">Simple process, real results</h2>
      </div>
      <div class="mt-14 grid grid-cols-1 gap-12 md:grid-cols-3">
        <div class="text-center">
          <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-accent text-xl font-bold text-white">
            1
          </div>
          <h3 class="mt-5 text-lg font-bold text-charcoal">Discovery call</h3>
          <p class="mt-2 text-sm leading-relaxed text-gray-500">
            We learn about your business, your pain points, and what you
            actually need -- no upselling.
          </p>
        </div>
        <div class="text-center">
          <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-accent text-xl font-bold text-white">
            2
          </div>
          <h3 class="mt-5 text-lg font-bold text-charcoal">We build it</h3>
          <p class="mt-2 text-sm leading-relaxed text-gray-500">
            Your site, booking system, or workflow goes live in days, not months.
            You review everything before launch.
          </p>
        </div>
        <div class="text-center">
          <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-accent text-xl font-bold text-white">
            3
          </div>
          <h3 class="mt-5 text-lg font-bold text-charcoal">You grow</h3>
          <p class="mt-2 text-sm leading-relaxed text-gray-500">
            More bookings, less admin, better online presence. We stick around
            for ongoing support.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="bg-gray-50 py-20" id="testimonials">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <p class="text-sm font-bold uppercase tracking-[0.2em] text-accent">Testimonials</p>
        <h2 class="mt-2 text-3xl font-black text-charcoal sm:text-4xl">What our clients say</h2>
      </div>
      <div class="mt-14 grid grid-cols-1 gap-8 md:grid-cols-2">
        <blockquote class="rounded-2xl border border-gray-100 bg-white p-8 shadow-sm">
          <div class="flex gap-1 text-energy">
            {Array(5).fill(null).map(() => (
              <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <p class="mt-4 leading-relaxed text-gray-600 italic">
            "I was paying for three different apps to manage my bookings, website, and
            marketing emails. doticrosst replaced all of them and it actually works better."
          </p>
          <footer class="mt-5">
            <p class="font-semibold text-charcoal">Sarah M.</p>
            <p class="text-sm text-gray-400">Salon Owner, Manchester</p>
          </footer>
        </blockquote>
        <blockquote class="rounded-2xl border border-gray-100 bg-white p-8 shadow-sm">
          <div class="flex gap-1 text-energy">
            {Array(5).fill(null).map(() => (
              <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <p class="mt-4 leading-relaxed text-gray-600 italic">
            "My website went from nowhere to the first page for 'barber near me' in six
            weeks. The phone hasn't stopped."
          </p>
          <footer class="mt-5">
            <p class="font-semibold text-charcoal">James T.</p>
            <p class="text-sm text-gray-400">Barbershop Owner, Edinburgh</p>
          </footer>
        </blockquote>
      </div>
    </div>
  </section>

  <CTAStrip />
</BaseLayout>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          const target = parseInt(el.dataset.target || "0", 10);
          let current = 0;
          const step = Math.ceil(target / 40);
          const interval = setInterval(() => {
            current += step;
            if (current >= target) {
              current = target;
              clearInterval(interval);
            }
            el.textContent = String(current);
          }, 30);
          observer.unobserve(el);
        }
      });
    },
    { threshold: 0.5 }
  );

  document.querySelectorAll(".stat-number").forEach((el) => observer.observe(el));
</script>
